# Environment Variables Example
# Copy this file to .env.local and fill in your values.
# NEVER commit real secrets here — this file is tracked in git. Real values
# belong in .env.local, which is gitignored.

# Site URL used by metadata/sitemap
NEXT_PUBLIC_SITE_URL=https://www.apexmotus.com

# OpenAI powers the hero business diagnostic.
# OPEN_AI_API is supported because the app is configured for that name.
# OPENAI_API_KEY also works if you prefer the standard OpenAI env var name.
OPEN_AI_API=sk-...
OPENAI_MODEL=gpt-5.4-mini

# EmailJS powers contact form email delivery (server-side REST API).
# Find these in your EmailJS dashboard:
#   SERVICE_ID  -> Email Services
#   TEMPLATE_ID -> Email Templates
#   PUBLIC_KEY  -> Account > General (a.k.a. User ID)
#   PRIVATE_KEY -> Account > General (a.k.a. Access Token) — KEEP SECRET
# IMPORTANT: enable Account > Security >
#   "Allow EmailJS API for non-browser applications" for server-side calls.
# The recipient ("To Email") and "Reply To" are configured in the EmailJS
# template settings (e.g. Reply To -> {{email_address}}), not here.
EMAILJS_SERVICE_ID=service_...
EMAILJS_PUBLIC_KEY=...
EMAILJS_PRIVATE_KEY=...
# Template used by the contact form (/api/contact).
EMAILJS_TEMPLATE_ID=template_...
# Template used by the hero business diagnostic (/api/diagnostic). Set its
# "To Email" to apex.motus.inc@gmail.com. Uses {{name}}, {{facts}}, {{message}}.
EMAILJS_DIAGNOSTIC_TEMPLATE_ID=template_...
